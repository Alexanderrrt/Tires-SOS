# Copy to .env.local for local development, and set production values in your
# hosting provider. Values prefixed NEXT_PUBLIC_ are intentionally browser-visible;
# never put secrets in them. All other keys below are server-only.

# Local end-to-end testing only. When set to 1, Supabase-backed stores use
# in-memory fallbacks and EmailJS notifications are disabled.
TIRES_SOS_E2E_TEST_MODE=0

# Canonical public origin, including https://. EmailJS uses this first for its
# Origin header; VERCEL_URL is used second when Vercel injects it automatically.
NEXT_PUBLIC_SITE_URL=https://tires-sos.vercel.app

# --- Admin panel auth (/admin) ---
# The password the shop owner types to log in and edit quote pricing.
ADMIN_PASSWORD=
# A long random string used to sign the admin session cookie.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# --- Supabase (stores editable pricing, chat leads, and appointments) ---
# From Supabase -> Project Settings -> API. Use the SERVICE ROLE key (server-only).
# Run db/pricing-schema.sql once in the Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI chat ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- MCP server (for Grok Voice Agent / other MCP clients, app/api/mcp) ---
# Bearer token the MCP client must send as "Authorization: Bearer <value>".
MCP_API_KEY=

# --- Public chat protection ---
# Signs anonymous chat sessions. When blank, the server falls back to AUTH_SECRET.
CHAT_SESSION_SECRET=
# Per-session request budget and window.
CHAT_RATE_LIMIT_MAX=12
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
# Maximum time allowed for the upstream AI request.
CHAT_REQUEST_TIMEOUT_MS=12000
# Cloudflare Turnstile is optional locally and recommended in production. Configure
# both values together when enabled; the site key is intentionally browser-visible.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Lead email notifications (EmailJS) ---
# From the EmailJS dashboard. EmailJS acceptance does not prove inbox delivery.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
# Required — no fallback exists in source. The inbox that receives new-lead
# alerts, e.g. leads@yourshop.com. Notifications are disabled until this is set.
NOTIFY_EMAIL_RECIPIENT=
