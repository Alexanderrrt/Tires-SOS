# Copy to .env.local for local dev, and set the same in Vercel → Settings →
# Environment Variables for production. NONE of these are NEXT_PUBLIC — they are
# server-only secrets and must never be exposed to the browser.

# --- Admin panel auth (/admin) ---
# The password the shop owner types to log in and edit quote pricing.
ADMIN_PASSWORD=change-me-to-a-strong-password
# A long random string used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# --- Supabase (stores the editable pricing) ---
# From Supabase → Project Settings → API. Use the SERVICE ROLE key (server-only).
# Run db/pricing-schema.sql once in the Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Without Supabase set, the quote calculator still works on the built-in default
# prices and the admin editor saves for the current session only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Lead SMS notifications (EmailJS → carrier gateway) ---
# From EmailJS dashboard. Sends an email-to-SMS when a new lead is captured.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
# Phone number with carrier gateway, e.g. 5551234567@vtext.com (Verizon),
# @tmomail.net (T-Mobile), @txt.att.net (AT&T). Defaults to 9834564801@vtext.com.
NOTIFY_SMS_RECIPIENT=
