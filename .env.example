# Copy to .env.local for local development, and set production values in your
# hosting provider. Values prefixed NEXT_PUBLIC_ are intentionally browser-visible;
# never put secrets in them. All other keys below are server-only.

# Local end-to-end testing only. When set to 1, Supabase-backed stores use
# in-memory fallbacks and email notifications are disabled.
TIRES_SOS_E2E_TEST_MODE=0

# Canonical public origin, including https://.
NEXT_PUBLIC_SITE_URL=https://tires-sos.vercel.app

# --- Admin panel auth (/admin) ---
# The password the shop owner types to log in and edit quote pricing.
ADMIN_PASSWORD=
# A long random string used to sign the admin session cookie.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# --- Supabase (stores editable pricing, chat leads, and appointments) ---
# From Supabase -> Project Settings -> API. Use the SERVICE ROLE key (server-only).
# Run db/pricing-schema.sql once in the Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stable client identity used by dashboard cron jobs when no client is supplied.
DASHBOARD_DEFAULT_CLIENT_ID=00000000-0000-4000-8000-000000000001
DASHBOARD_DEFAULT_CLIENT_EMAIL=tiressosrescue@gmail.com

# Encrypts Google/Meta/Yelp credentials before Supabase persistence.
# Generate with: openssl rand -base64 32
AD_CONNECTIONS_ENCRYPTION_KEY=

# --- Clerk auth for /dashboard ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated Clerk user IDs. Authentication alone never grants access.
DASHBOARD_ALLOWED_USER_IDS=

# --- AI chat ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Public chat protection ---
# Signs anonymous chat sessions. When blank, the server falls back to AUTH_SECRET.
CHAT_SESSION_SECRET=
# Per-session request budget and window.
CHAT_RATE_LIMIT_MAX=12
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
# Maximum time allowed for the upstream AI request.
CHAT_REQUEST_TIMEOUT_MS=12000
# Cloudflare Turnstile is optional locally and recommended in production. Configure
# both values together when enabled; the site key is intentionally browser-visible.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Email notifications ---
# All owner-facing email (chat/appointment leads, weekly reports, budget
# alerts, admin test-notify) sends via Gmail (see GMAIL_* below) to this
# address. No third-party email service is used.
NOTIFY_EMAIL_RECIPIENT=tires@tiressosrescue.com

# --- PostHog weekly website analytics ---
# Browser-visible project token used only to capture events.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-only personal API key with Query Read access for project 513826.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=513826
POSTHOG_APP_HOST=https://us.posthog.com
# Long random bearer tokens used by Vercel cron and the report publishing API.
CRON_SECRET=
ANALYTICS_REPORTS_API_KEY=

# --- Gmail API (read-only + modify, Yelp lead auto-responder) ---
# Google Cloud OAuth client credentials + a refresh token for the Gmail inbox
# that receives Yelp "Request a Quote" lead emails. Generate the refresh token
# once with: node scripts/gmail-oauth-setup.js
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Gmail send-from identity (used for Yelp replies AND all owner
# notifications above, since Gmail is the only email transport now) ---
# Should match the actual email on the Yelp business account (Account settings
# -> Email address) so Yelp's message-relay system (reply+id@messaging.yelp.com)
# correctly routes the reply back into the customer's Yelp conversation —
# a reply from an unrelated address may not be attributed to the business.
YELP_REPLY_FROM_EMAIL=angeltamayo@tiressosrescue.com
YELP_REPLY_FROM_NAME=Tires SOS Rescue
